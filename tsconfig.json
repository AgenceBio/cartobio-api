{
  "include": [
    "server.d.ts",
    "lib/**/*.js",
    "lib/types.d.ts"
  ],
  "exclude": [
    "**/*.test.js"
  ],
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "resolveJsonModule": false,
    "lib": [
      "es2023",
    ],
    "skipLibCheck": true
  }
}
